# OpenClaw Gateway Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Chat IDs that are allowed to interact (comma-separated)
# To find your chat ID, send a message to @userinfobot on Telegram
TELEGRAM_ALLOWED_CHAT_IDS=

# Gateway port (default: 3004)
OPENCLAW_PORT=3004

# OpenClaw skills directory
OPENCLAW_SKILLS_DIR=F:\P2A-Althena\openclaw-skills

# MCP Agent URL (default: http://localhost:3002)
MCP_URL=http://localhost:3002

# FIWARE Orion URL (default: http://localhost:1026)
ORION_URL=http://localhost:1026

# FIMAT Agent URL (default: http://localhost:3000)
FIMAT_URL=http://localhost:3000

# Zigbee Bridge URL (default: http://localhost:3003)
ZIGBEE_URL=http://localhost:3003

# Alert polling interval in ms (default: 5000)
ALERT_POLL_INTERVAL=5000

# Alert cooldown per zone in ms (default: 30000)
ALERT_COOLDOWN_MS=30000
