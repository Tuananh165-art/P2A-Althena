# MCP Agent Configuration

# Orion Context Broker
ORION_HOST=localhost
ORION_PORT=1026

# MCP Agent
MCP_PORT=3002
MCP_POLL_INTERVAL=5000

# Device control
# simulator: update Orion directly for demo data
# live: send through the real Matter/Zigbee bridge and wait for reported state
DEVICE_CONTROL_MODE=simulator
DEVICE_CONFIRMATION_TIMEOUT_MS=8000
DEVICE_CONFIRMATION_POLL_MS=400
ZIGBEE_BRIDGE_HOST=localhost
ZIGBEE_BRIDGE_PORT=3003

# Risk Engine
RISK_COOLDOWN_MS=30000

# AI Reasoning (optional - leave empty for rule-based only)
# Supports OpenAI-compatible endpoints (OpenAI, Azure, Claude via proxy, local LLMs)
AI_ENDPOINT=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ANALYZE_ENABLED=0
AI_ANALYZE_TIMEOUT_MS=20000
AI_CHAT_TIMEOUT_MS=60000
